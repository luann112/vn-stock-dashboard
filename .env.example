# VN Stock Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values.

# ── API ──────────────────────────────────────────────────────────────────────
# FastAPI backend URL (local dev or Railway production)
NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_URL=https://vn-stock-api-production.up.railway.app

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
